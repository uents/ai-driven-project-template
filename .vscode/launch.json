{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: 現在のファイル",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Python: pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-c", "${workspaceFolder}/pytest.ini",
        "--cov-config=${workspaceFolder}/.coveragerc",
        "-v",
        "${file}"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Python: pytest (カバレッジ付き)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-c", "${workspaceFolder}/pytest.ini",
        "--cov",
        "--cov-config=${workspaceFolder}/.coveragerc",
        "--cov-report=term-missing",
        "-v"
      ],
      "console": "integratedTerminal"
    }
  ]
}
